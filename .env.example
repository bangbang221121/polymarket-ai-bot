# Polymarket API 인증
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here

# 지갑 프라이빗 키 (0x 제외, 64자리 hex)
POLYMARKET_PRIVATE_KEY=abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# AI 분석용 OpenAI API 키
OPENAI_API_KEY=sk-your_openai_key_here

# 베팅 설정
BET_AMOUNT=10
MAX_DAILY_LOSS=100

# 시장 ID (Polymarket에서 확인 필요)
# Bitcoin Up/Down 5min 시장의 token_id
BTC_MARKET_ID=0x...
# Ethereum Up/Down 5min 시장의 token_id  
ETH_MARKET_ID=0x...
